{
  "name": "lpc-forge",
  "version": "1.0.4",
  "description": "Complete 2D RPG asset pipeline — character compositor, procedural map generator, and Godot 4.6 exporter. Built on Liberated Pixel Cup sprites.",
  "type": "module",
  "bin": {
    "lpc-forge": "dist/cli.js"
  },
  "files": [
    "dist/cli.js",
    "dist/cli.d.ts",
    "dist/character/**",
    "dist/map/**",
    "dist/export/**",
    "dist/tileset/**",
    "dist/utils/**",
    "dist/license.js",
    "dist/license.d.ts",
    "dist/assets/**",
    "dist/lighting/**",
    "dist/audio/**",
    "dist/ui/**",
    "dist/systems/**",
    "assets/**",
    "README.md",
    "LICENSE",
    "CREDITS.csv",
    "package.json"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "lint": "eslint src/",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "lpc",
    "liberated-pixel-cup",
    "spritesheet",
    "character-generator",
    "godot",
    "godot-4",
    "gamedev",
    "pixel-art",
    "rpg",
    "2d",
    "procedural-generation",
    "dungeon-generator",
    "tilemap",
    "indie-game",
    "game-assets",
    "sprite-compositor"
  ],
  "author": "LaunchDay Studio <info@launchdaystudio.com> (https://blueth.online)",
  "license": "GPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "https://github.com/LaunchDay-Studio-Inc/lpc-forge.git"
  },
  "bugs": {
    "url": "https://github.com/LaunchDay-Studio-Inc/lpc-forge/issues"
  },
  "homepage": "https://blueth.online",
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "chalk": "^5.4.0",
    "commander": "^13.0.0",
    "glob": "^11.0.0",
    "jsfxr": "^1.4.0",
    "ora": "^8.2.0",
    "sharp": "^0.34.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "8.57.1",
    "vitest": "^3.0.0"
  }
}
